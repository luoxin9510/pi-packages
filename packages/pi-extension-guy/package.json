{
  "name": "@nukcole-xinluo9510/pi-extension-guy",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Pi extension — a control panel to hot enable/disable your local extensions by typing /extensions",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "manager",
    "toggle",
    "hot-reload"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luoxin9510/pi-packages.git",
    "directory": "packages/pi-extension-guy"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "files": [
    "extensions",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
